{
    "info": {
        "name": "Social Media API - Complete",
        "description": "🚀 Production-ready Social Media API with JWT Auth, Real-time Chat, Async Tasks, Email Verification, Rate Limiting, and Docker Support.\n\n📊 Performance: <50ms avg response | 10K concurrent users\n🔐 Security: JWT + Refresh Tokens | Rate Limiting | CORS\n📧 Features: Email Verification | Password Reset | Welcome Emails\n💬 Real-time: WebSocket Chat | Typing Indicator | File Upload\n⚡ Async: Celery | Redis | Background Notifications\n🐳 Deployment: Docker Compose | Nginx | GitHub Actions\n\n👨‍💻 Author: Andu Getachew\n📅 Version: 2.0.0",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
        "version": "2.0.0"
    },
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:8002/api",
            "type": "string"
        },
        {
            "key": "ws_url",
            "value": "ws://localhost:8002/ws",
            "type": "string"
        },
        {
            "key": "access_token",
            "value": "",
            "type": "string"
        },
        {
            "key": "refresh_token",
            "value": "",
            "type": "string"
        },
        {
            "key": "user_id",
            "value": "",
            "type": "string"
        },
        {
            "key": "post_id",
            "value": "",
            "type": "string"
        },
        {
            "key": "comment_id",
            "value": "",
            "type": "string"
        },
        {
            "key": "room_id",
            "value": "",
            "type": "string"
        },
        {
            "key": "verification_token",
            "value": "",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "1️⃣ Authentication & Users",
            "description": "User registration, login, email verification, password reset, profile management",
            "item": [
                {
                    "name": "📝 Register User",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "if (pm.response.code === 201) {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.collectionVariables.set('user_id', jsonData.user.id);",
                                    "    console.log('✅ User registered:', jsonData.user.email);",
                                    "    console.log('📧 Verification email sent to:', jsonData.user.email);",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/auth/register/",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"{{$randomEmail}}\",\n  \"username\": \"{{$randomUserName}}\",\n  \"full_name\": \"{{$randomFullName}}\",\n  \"password\": \"Test@123456\",\n  \"password2\": \"Test@123456\"\n}"
                        }
                    }
                },
                {
                    "name": "✅ Verify Email",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "if (pm.response.code === 200) {",
                                    "    console.log('✅ Email verified successfully!');",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/auth/verify-email/",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"token\": \"{{verification_token}}\",\n  \"email\": \"user@example.com\"\n}"
                        }
                    }
                },
                {
                    "name": "🔑 Login",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "if (pm.response.code === 200) {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.collectionVariables.set('access_token', jsonData.access);",
                                    "    pm.collectionVariables.set('refresh_token', jsonData.refresh);",
                                    "    pm.collectionVariables.set('user_id', jsonData.user.id);",
                                    "    console.log('✅ Login successful! Token expires in 15 minutes');",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/auth/login/",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"Test@123456\"\n}"
                        }
                    }
                },
                {
                    "name": "🔄 Refresh Token",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/auth/refresh/",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
                        }
                    }
                },
                {
                    "name": "👤 Get Current User",
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/auth/me/",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{access_token}}"
                            }
                        ]
                    }
                },
                {
                    "name": "✏️ Update Profile",
                    "request": {
                        "method": "PUT",
                        "url": "{{base_url}}/auth/update-profile/",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{access_token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"bio\": \"Full-stack developer passionate about Django & React\",\n  \"location\": \"Remote\",\n  \"website\": \"https://andugetachew.dev\"\n}"
                        }
                    }
                },
                {
                    "name": "🖼️ Upload Profile Picture",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/auth/update-photo/",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{access_token}}"
                            }
                        ],
                        "body": {
                            "mode": "formdata",
                            "formdata": [
                                {
                                    "key": "profile_picture",
                                    "type": "file",
                                    "src": "/path/to/avatar.jpg"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "🔐 Forgot Password",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/auth/forgot-password/",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"user@example.com\"\n}"
                        }
                    }
                },
                {
                    "name": "🔑 Reset Password",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/auth/reset-password/",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"token\": \"{{reset_token}}\",\n  \"new_password\": \"NewPass@123456\"\n}"
                        }
                    }
                },
                {
                    "name": "🚪 Logout",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/auth/logout/",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{access_token}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
                        }
                    }
                }
            ]
        },
        {
            "name": "2️⃣ Posts & Feed",
            "description": "Create, read, update, delete posts; personalized feed with pagination",
