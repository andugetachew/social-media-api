    "auth": {
        "type": "bearer",
        "bearer": [
            {
                "key": "token",
                "value": "{{access_token}}",
                "type": "string"
            }
        ]
    },
    "event": [
        {
            "listen": "prerequest",
            "script": {
                "exec": [
                    "console.log('🚀 Sending request to:', pm.request.url);",
                    "console.log('⏰ Time:', new Date().toISOString());"
                ]
            }
        },
        {
            "listen": "test",
            "script": {
                "exec": [
                    "if (pm.response.code >= 200 && pm.response.code < 300) {",
                    "    console.log('✅ Request successful:', pm.response.code);",
                    "} else if (pm.response.code === 429) {",
                    "    console.warn('⚠️ Rate limit exceeded. Wait a moment.');",
                    "} else if (pm.response.code === 401) {",
                    "    console.warn('⚠️ Token expired. Please login again.');",
                    "}"
                ]
            }
        }
    ]
}