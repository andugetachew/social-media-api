                                    "type": "text"
                                },
                                {
                                    "key": "image",
                                    "type": "file",
                                    "src": "/path/to/image.jpg"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "📋 Get My Posts",
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/posts/",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{access_token}}"
                            }
                        ]
                    }
                },
                {
                    "name": "🔥 Get Feed (Personalized)",
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/posts/feed/?page=1&page_size=20",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{access_token}}"
                            }
                        ]
                    }
                },
                {
                    "name": "✏️ Update Post",
                    "request": {
                        "method": "PUT",
                        "url": "{{base_url}}/posts/{{post_id}}/update/",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{access_token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"content\": \"Updated: This post has been edited!\"\n}"
                        }
                    }
                },
                {
                    "name": "🗑️ Delete Post",
                    "request": {
                        "method": "DELETE",
                        "url": "{{base_url}}/posts/{{post_id}}/",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{access_token}}"
                            }
                        ]
                    }
                }
            ]
